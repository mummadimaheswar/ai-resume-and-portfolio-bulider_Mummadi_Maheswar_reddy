# AI Resume & Portfolio Builder - Environment Configuration
# Copy this file to .env and fill in your values

# ==================== REQUIRED ====================
# Get your free API key at: https://makersuite.google.com/app/apikey
# Primary variable used by the app:
GEMINI_API_KEY=your_gemini_api_key_here

# Alias supported for convenience (same value as above):
GOOGLE_API_KEY=your_gemini_api_key_here

# ==================== OPTIONAL ====================
# AI Model Selection (default: gemini-1.5-flash)
# Options: gemini-1.5-flash (faster, free) or gemini-1.5-pro (better quality)
GEMINI_MODEL=gemini-1.5-flash

# Output Directory (default: outputs)
OUTPUT_DIR=outputs

# Debug Mode (default: False)
# Set to True for detailed error messages during development
DEBUG=False
